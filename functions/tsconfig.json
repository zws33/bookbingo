{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "rootDir": "src",
    "outDir": "lib",
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "lib": ["es2022"],
    "composite": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  "references": [
    { "path": "../lib/types/tsconfig.build.json" },
    { "path": "../lib/util/tsconfig.build.json" }
  ]
}
