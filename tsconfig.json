{
  "extends": "./tsconfig.build.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@bookbingo/lib-core": ["lib/core/src/index.ts"],
      "@bookbingo/lib-types": ["lib/types/src/index.ts"]
    }
  },
  "include": ["app/**/*", "lib/**/*", "docs/**/*"],
  "exclude": ["**/node_modules", "**/dist", "**/build"]
}
