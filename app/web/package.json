{
  "name": "@bookbingo/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "vite --mode emulator",
    "dev:staging": "vite --mode staging",
    "dev:prod": "vite --mode prod",
    "build": "pnpm run build:prod",
    "build:staging": "tsc -b tsconfig.build.json && vite build --mode staging",
    "build:prod": "tsc -b tsconfig.build.json && vite build --mode prod",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.config.int.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@bookbingo/lib-core": "workspace:*",
    "@bookbingo/lib-types": "workspace:*",
    "@bookbingo/lib-util": "workspace:*",
    "firebase": "^10.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-firebase-hooks": "^5.1.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@tailwindcss/vite": "^4.2.2",
    "firebase-admin": "^13.7.0",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.3.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
