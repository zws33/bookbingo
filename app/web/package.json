{
  "name": "@bookbingo/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:emulator": "vite --mode emulator",
    "dev:staging": "vite --mode staging",
    "dev:prod": "vite --mode prod",
    "emulator:start": "firebase emulators:start --import=./emulator-data --export-on-exit ./emulator-data",
    "emulator:seed": "FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 tsx scripts/seed-emulator.ts",
    "build": "pnpm run build:prod",
    "build:staging": "tsc -b tsconfig.build.json && vite build --mode staging",
    "build:prod": "tsc -b tsconfig.build.json && vite build --mode prod",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --ignore-pattern dist --report-unused-disable-directives --max-warnings 0",
    "deploy:prod": "pnpm run build:prod && firebase deploy --only hosting,firestore:rules",
    "deploy:staging": "pnpm run build:staging && firebase deploy --only hosting,firestore:rules --project staging"
  },
  "dependencies": {
    "@bookbingo/lib-core": "workspace:*",
    "@bookbingo/lib-types": "workspace:*",
    "firebase": "^10.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-firebase-hooks": "^5.1.1",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "firebase-admin": "^13.7.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "vite": "^5.1.0"
  }
}
