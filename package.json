{
  "name": "bookbingo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "pnpm --filter @bookbingo/cli dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"app/**/*.ts\" \"lib/**/*.ts\"",
    "build": "tsc --build",
    "build:libs": "tsc --build lib/*",
    "build:apps": "tsc --build app/*",
    "typecheck": "tsc --build --noEmit",
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter @bookbingo/web dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.18.0",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
