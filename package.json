{
  "name": "bookbingo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "pnpm -r test",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write \"app/**/*.ts\" \"lib/**/*.ts\"",
    "build": "tsc --build",
    "build:libs": "tsc --build lib/*",
    "build:apps": "tsc --build app/*",
    "typecheck": "tsc --build --noEmit && pnpm --filter @bookbingo/functions exec tsc --noEmit",
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter @bookbingo/web dev",
    "dev:web:emulator": "pnpm --filter @bookbingo/web dev:emulator",
    "dev:web:staging": "pnpm --filter @bookbingo/web dev:staging",
    "dev:web:prod": "pnpm --filter @bookbingo/web dev:prod",
    "deploy:staging": "pnpm --filter @bookbingo/web build:staging && firebase deploy --only hosting,firestore:rules --project staging",
    "deploy:prod": "pnpm --filter @bookbingo/web build:prod && firebase deploy --only hosting,firestore:rules",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:all:staging": "pnpm --filter @bookbingo/web build:staging && firebase deploy --project staging",
    "deploy:all:prod": "pnpm --filter @bookbingo/web build:prod && firebase deploy",
    "emulator:start": "firebase emulators:start --project demo-bookbingo --import=./emulator-data --export-on-exit ./emulator-data",
    "emulator:seed": "FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 tsx scripts/seed-emulator.ts",
    "test:integration": "firebase emulators:exec --project demo-bookbingo 'pnpm --filter @bookbingo/web test:integration'",
    "verify": "pnpm run lint && pnpm test && pnpm run typecheck",
    "dev:local": "concurrently --kill-others --names 'emulator,web' 'pnpm run emulator:start' 'pnpm run dev:web:emulator'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^22.10.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "firebase-admin": "^13.7.0",
    "globals": "^17.0.0",
    "prettier": "^3.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.18.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "dependencies": {
    "firebase-admin": "^13.7.0"
  }
}
