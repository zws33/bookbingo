rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Shared books collection
    match /books/{bookId} {
      allow read, list: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (request.auth.uid == resource.data.createdBy || resource.data.createdBy == 'system-migration');
    }

    // User profiles and their private readings
    match /users/{userId} {
      allow read, list: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /readings/{readingId} {
        allow read, list: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Required for collectionGroup('readings') queries (e.g. leaderboard).
    match /{path=**}/readings/{readingId} {
      allow read, list: if request.auth != null;
    }
  }
}
